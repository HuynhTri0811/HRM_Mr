{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.MongoDB"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Mvc": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MongoDB",
        "Args": {
          "databaseUrl": "mongodb://mongo:mongo@mongodb:27017/HrmLogsDb?authSource=admin",
          "collectionName": "TinhLuongLogs",
          "period": "00:00:10"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=DbTinhLuong;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "SuperSecretKeyForJwtAuthenticationWhichIsVeryLong!123",
    "Issuer": "QuanLyNhanSuMicroservice",
    "Audience": "QuanLyNhanSuMicroservice"
  },
  "NhanSuApiUrl": "http://nhansu-api:8081"
}